# 复制为 .env.yaml 或通过 docker env 覆盖 dev.yaml 中的默认值
# 生产环境请务必修改所有密码和密钥

cors_hosts:
  - "https://your-domain.example.com"

# JWT 密钥（生产必须改！32 字节随机字符串）
secret_key: "CHANGE_ME_TO_RANDOM_32_BYTES"
access_token_expire_minutes: 1440

# 下载器
downloader_type: "qbittorrent"
downloader_host: "http://qbittorrent:8080"
downloader_username: "admin"
downloader_password: "CHANGE_ME"

# 数据库
database_url: "postgres://anidog:CHANGE_ME@postgres:5432/anidog?sslmode=disable"
db_max_open_conns: 25
db_max_idle_conns: 5

# 默认规则
enable_default_rules: true
default_rule_name: "mikan"

# 日志
log_level: "INFO"

# RSS
rss_check_interval: 30

# 流媒体
stream_max_concurrent: 3
rod_headless: true
stream_intercept_timeout: 30

# TMDB
tmdb_language: "zh-CN"
tmdb_base_url: "https://api.themoviedb.org/3"
# tmdb_api_key: ""   # 如需 TMDB 元信息请填入

# 通知（Bark/Webhook 等）
enable_notifications: false
