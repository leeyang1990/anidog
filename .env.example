# 复制为 .env；docker compose 会自动读取
# 生产部署必须修改所有 CHANGE_ME

# ── 镜像版本 ──
# 镜像固定从 Docker Hub 的 leeyang1990/anidog-backend 和 anidog-frontend 拉取
# 要部署的版本 tag；缺省 latest（指向最新发布）
TAG=latest
# 前端对外端口（浏览器访问 http://<host>:<此端口>）
FRONTEND_PORT=3002

# PostgreSQL
POSTGRES_DB=anidog
POSTGRES_USER=anidog
POSTGRES_PASSWORD=CHANGE_ME

# JWT 签名密钥（32 字节随机字符串，可用 openssl rand -hex 32 生成）
SECRET_KEY=CHANGE_ME_TO_RANDOM_32_BYTES

# qBittorrent WebUI
DOWNLOADER_USERNAME=admin
DOWNLOADER_PASSWORD=CHANGE_ME

# 其他
LOG_LEVEL=INFO
RSS_CHECK_INTERVAL=30
CORS_HOSTS=http://localhost:3002
TZ=Asia/Shanghai

# 可选：TMDB
# TMDB_API_KEY=
